APP_ENV=local
APP_NAME=gift-ingestion-backend
API_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://gift_user:gift_pass@localhost:5432/gift_ingestion
RAW_STORAGE_ROOT=./raw_storage
LOG_LEVEL=INFO
DEFAULT_REQUEST_TIMEOUT_SECONDS=30
ONECAUSE_DEFAULT_BASE_URL=https://api.onecause.com
ONECAUSE_PORTAL_URL=https://p2p.onecause.com/client/login
ONECAUSE_PORTAL_USERNAME=
ONECAUSE_PORTAL_PASSWORD=
ONECAUSE_DOCS_URL=https://help.onecause.com/s/article/api-documentation
ONECAUSE_DOCS_USERNAME=
ONECAUSE_DOCS_PASSWORD=
ONECAUSE_API_BASE_URL=https://api.onecause.com
ONECAUSE_API_KEY=
ONECAUSE_ORGANIZATION_ID=
ONECAUSE_CLIENT_ID=
ONECAUSE_ACCESS_TOKEN=
ONECAUSE_CHALLENGE_ID=
PLEDGE_API_BASE_URL=https://api.pledge.to
PLEDGE_API_KEY=
EVERYORG_PUBLIC_API_BASE_URL=https://partners.every.org
EVERYORG_PUBLIC_KEY=
EVERYORG_PRIVATE_KEY=
EVERYORG_WEBHOOK_TOKEN=
EVERYORG_WEBHOOK_KIND=nonprofit
EVERYORG_NONPROFIT_SLUG=
ENABLE_INPROCESS_SCHEDULER=true
SCHEDULER_POLL_SECONDS=60
